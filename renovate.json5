{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>AzisabaNetwork/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Automerge test dependency updates (kotest, MockBukkit, H2)",
      "groupName": "test dependencies",
      "matchDepTypes": ["test"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge minor and patch updates for Gradle plugins",
      "groupName": "gradle plugins",
      "matchDepTypes": ["plugin"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge GitHub Actions updates after 14 days",
      "groupName": "github actions",
      "matchDepTypes": ["action"],
      "minimumReleaseAge": "14 days",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Disable automerge for Paper API (Minecraft version-sensitive)",
      "groupName": "paper",
      "matchPackageNames": [
        "io.papermc.paper:paper-api"
      ],
      "automerge": false
    }
  ]
}
