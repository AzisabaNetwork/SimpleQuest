{
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "versioning": "always-bump-patch",
      "extra-files": [
        {
          "type": "gradle",
          "path": "build.gradle.kts",
          "pattern": "version = \"$version\""
        }
      ]
    }
  }
}
